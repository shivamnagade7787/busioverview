rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "shivamnagade@gmail.com";
    }

    function hasBusinessAccess(bizId) {
      return isAuthenticated() && 
        (isSuperAdmin() || (bizId != null && bizId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('businessIds', [])));
    }

    function canAccessDoc() {
      return isSuperAdmin() || isDocOwner() || hasBusinessAccess(resource.data.get('businessId', null));
    }

    function canCreateDoc(data) {
      return isSuperAdmin() || (isNewDocOwner() && hasBusinessAccess(data.get('businessId', null)));
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid;
    }

    function isValidBusiness(data) {
      return data.id is string && data.name is string;
    }

    function isValidParty(data) {
      return data.name is string &&
             data.type in ['customer', 'supplier'] &&
             data.balance is number;
    }

    function isValidProduct(data) {
      return data.name is string &&
             data.salePrice is number &&
             data.stockQuantity is number;
    }

    function isValidInvoice(data) {
      return data.partyId is string &&
             data.type in ['sale', 'purchase', 'estimate', 'proforma'] &&
             data.grandTotal is number;
    }

    function isValidExpense(data) {
      return data.category is string &&
             data.amount is number;
    }

    function isValidBankAccount(data) {
      return data.bankName is string &&
             data.balance is number;
    }

    function isValidLedger(data) {
      return data.partyId is string &&
             data.type in ['credit', 'debit'] &&
             data.amount is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isSuperAdmin();
      allow create, update: if (isOwner(userId) || isSuperAdmin()) && isValidUserProfile(request.resource.data);
    }

    match /businesses/{bizId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated(); // Should probably be more restricted but okay for joining
      allow create, update: if isAuthenticated() && isValidBusiness(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /parties/{partyId} {
      allow get, list: if canAccessDoc();
      allow create: if canCreateDoc(request.resource.data) && isValidParty(request.resource.data);
      allow update: if canAccessDoc() && isValidParty(request.resource.data);
      allow delete: if canAccessDoc();
    }

    match /products/{productId} {
      allow get, list: if canAccessDoc();
      allow create: if canCreateDoc(request.resource.data) && isValidProduct(request.resource.data);
      allow update: if canAccessDoc() && isValidProduct(request.resource.data);
      allow delete: if canAccessDoc();
    }

    match /invoices/{invoiceId} {
      allow get, list: if canAccessDoc();
      allow create: if canCreateDoc(request.resource.data) && isValidInvoice(request.resource.data);
      allow update: if canAccessDoc() && isValidInvoice(request.resource.data);
      allow delete: if canAccessDoc();
    }

    match /expenses/{expenseId} {
      allow get, list: if canAccessDoc();
      allow create: if canCreateDoc(request.resource.data) && isValidExpense(request.resource.data);
      allow update: if canAccessDoc() && isValidExpense(request.resource.data);
      allow delete: if canAccessDoc();
    }

    match /bank_accounts/{accountId} {
      allow get, list: if canAccessDoc();
      allow create: if canCreateDoc(request.resource.data) && isValidBankAccount(request.resource.data);
      allow update: if canAccessDoc() && isValidBankAccount(request.resource.data);
      allow delete: if canAccessDoc();
    }

    match /ledger/{entryId} {
      allow get, list: if canAccessDoc();
      allow create: if canCreateDoc(request.resource.data) && isValidLedger(request.resource.data);
      allow update: if canAccessDoc() && isValidLedger(request.resource.data);
      allow delete: if canAccessDoc();
    }
  }
}
