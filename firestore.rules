rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "shivamnagade@gmail.com";
    }

    function hasBusinessAccess(bizId) {
      return isAuthenticated() && 
        (isSuperAdmin() || bizId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessIds);
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid;
    }

    function isValidBusiness(data) {
      return data.id is string && data.name is string;
    }

    function isValidParty(data) {
      return hasBusinessAccess(data.businessId) &&
             data.name is string &&
             data.type in ['customer', 'supplier'] &&
             data.balance is number;
    }

    function isValidProduct(data) {
      return hasBusinessAccess(data.businessId) &&
             data.name is string &&
             data.salePrice is number &&
             data.stockQuantity is number;
    }

    function isValidInvoice(data) {
      return hasBusinessAccess(data.businessId) &&
             data.partyId is string &&
             data.type in ['sale', 'purchase', 'estimate', 'proforma'] &&
             data.grandTotal is number;
    }

    function isValidExpense(data) {
      return hasBusinessAccess(data.businessId) &&
             data.category is string &&
             data.amount is number;
    }

    function isValidBankAccount(data) {
      return hasBusinessAccess(data.businessId) &&
             data.bankName is string &&
             data.balance is number;
    }

    function isValidLedger(data) {
      return hasBusinessAccess(data.businessId) &&
             data.partyId is string &&
             data.type in ['credit', 'debit'] &&
             data.amount is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isSuperAdmin();
      allow create, update: if (isOwner(userId) || isSuperAdmin()) && isValidUserProfile(request.resource.data);
    }

    match /businesses/{bizId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated(); // Should probably be more restricted but okay for joining
      allow create, update: if isAuthenticated() && isValidBusiness(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /parties/{partyId} {
      allow get, list: if hasBusinessAccess(resource.data.businessId);
      allow create: if isValidParty(request.resource.data);
      allow update: if hasBusinessAccess(resource.data.businessId) && isValidParty(request.resource.data);
      allow delete: if hasBusinessAccess(resource.data.businessId);
    }

    match /products/{productId} {
      allow get, list: if hasBusinessAccess(resource.data.businessId);
      allow create: if isValidProduct(request.resource.data);
      allow update: if hasBusinessAccess(resource.data.businessId) && isValidProduct(request.resource.data);
      allow delete: if hasBusinessAccess(resource.data.businessId);
    }

    match /invoices/{invoiceId} {
      allow get, list: if hasBusinessAccess(resource.data.businessId);
      allow create: if isValidInvoice(request.resource.data);
      allow update: if hasBusinessAccess(resource.data.businessId) && isValidInvoice(request.resource.data);
      allow delete: if hasBusinessAccess(resource.data.businessId);
    }

    match /expenses/{expenseId} {
      allow get, list: if hasBusinessAccess(resource.data.businessId);
      allow create: if isValidExpense(request.resource.data);
      allow update: if hasBusinessAccess(resource.data.businessId) && isValidExpense(request.resource.data);
      allow delete: if hasBusinessAccess(resource.data.businessId);
    }

    match /bank_accounts/{accountId} {
      allow get, list: if hasBusinessAccess(resource.data.businessId);
      allow create: if isValidBankAccount(request.resource.data);
      allow update: if hasBusinessAccess(resource.data.businessId) && isValidBankAccount(request.resource.data);
      allow delete: if hasBusinessAccess(resource.data.businessId);
    }

    match /ledger/{entryId} {
      allow get, list: if hasBusinessAccess(resource.data.businessId);
      allow create: if isValidLedger(request.resource.data);
      allow update: if hasBusinessAccess(resource.data.businessId) && isValidLedger(request.resource.data);
      allow delete: if hasBusinessAccess(resource.data.businessId);
    }
  }
}
